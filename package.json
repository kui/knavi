{
  "private": true,
  "name": "knavi",
  "version": "4.0.0",
  "description": "Hit-a-Hint with magic key. You can click without the mouse by holding down the space key and hint text.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.ts",
    "zip": "node scripts/zip.ts",
    "clean": "node scripts/clean.ts",
    "lint": "run-s lint:eslint lint:prettier lint:tsc:** lint:changelog",
    "lint:eslint": "eslint --flag unstable_native_nodejs_ts_config .",
    "lint:prettier": "prettier . --check",
    "lint:tsc:root": "tsc --project . --noEmit",
    "lint:tsc:src:lib": "tsc --project src/tsconfig.lib.json --noEmit",
    "lint:tsc:src:background": "tsc --project src/tsconfig.background.json --noEmit",
    "lint:tsc:src:dom": "tsc --project src/tsconfig.dom.json --noEmit",
    "lint:tsc:src:content-all": "tsc --project src/tsconfig.content-all.json --noEmit",
    "lint:tsc:src:content-root": "tsc --project src/tsconfig.content-root.json --noEmit",
    "lint:tsc:src:options": "tsc --project src/tsconfig.options.json --noEmit",
    "lint:tsc:test": "tsc --project test --noEmit",
    "lint:tsc:test:e2e": "tsc --project test/e2e --noEmit",
    "lint:tsc:scripts": "tsc --project scripts --noEmit",
    "lint:changelog": "./scripts/lint_changelog.bash",
    "fix": "run-s fix:eslint fix:prettier",
    "fix:eslint": "eslint --flag unstable_native_nodejs_ts_config . --fix",
    "fix:prettier": "prettier . --write",
    "test": "node --test test/lib/*.test.ts",
    "test:e2e": "playwright test",
    "check": "run-s lint test",
    "watch": "run-p watch:build watch:serve",
    "watch:build": "chokidar src -c 'npm run build'",
    "watch:serve": "http-server docs -d=false -c=-1"
  },
  "author": "Keiichiro Ui<keiichiro.ui@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.0.0",
    "chokidar-cli": "^3.0.0",
    "esbuild": "0.28.0",
    "eslint": "^10.4.1",
    "glob-trie.js": "^0.2.1",
    "globals": "^17.6.0",
    "http-server": "^14.1.1",
    "json5": "^2.2.3",
    "jszip": "^3.10.1",
    "key-input-elements": "^2.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "storage-form": "^2.2.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "repository": "git@github.com:kui/knavi.git"
}
